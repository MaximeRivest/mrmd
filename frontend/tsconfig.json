{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "/editor-dist/index.browser.js": ["core/editor-dist.d.ts"],
      "/core/ipython-client.js": ["core/ipython-client.ts"]
    }
  },
  "include": [
    "core/globals.d.ts",
    "core/editor-dist.d.ts",
    "core/*.ts",
    "src"
  ],
  "exclude": ["node_modules", "dist"]
}
